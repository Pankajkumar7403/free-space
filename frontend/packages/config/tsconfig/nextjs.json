{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Next.js",
    "extends": "./base.json",
    "compilerOptions": {
      "target": "ES2017",
      "lib": ["DOM", "DOM.Iterable", "ES2022"],
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "jsx": "preserve",
      "allowJs": true,
      "plugins": [{ "name": "next" }]
    },
    "include": ["src", "next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.d.ts"],
    "exclude": ["node_modules"]
  }
  
