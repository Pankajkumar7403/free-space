{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "React Native / Expo",
    "extends": "./base.json",
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["ES2020"],
      "jsx": "react-native",
      "allowJs": true,
      "moduleResolution": "node",
      "module": "CommonJS",
      "noUncheckedIndexedAccess": false,
      "exactOptionalPropertyTypes": false,
      "strict": true,
      "noImplicitAny": true
    },
    "exclude": ["node_modules"]
  }