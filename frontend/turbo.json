
{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "inputs": ["$TURBO_DEFAULT$", ".env*"],
        "outputs": [".next/**", "!.next/cache/**", "dist/**", ".expo/**"]
      },
      "dev": {
        "cache": false,
        "persistent": true
      },
      "lint": {
        "dependsOn": ["^lint"]
      },
      "type-check": {
        "dependsOn": ["^type-check"]
      },
      "test": {
        "dependsOn": ["^build"],
        "inputs": ["$TURBO_DEFAULT$"],
        "outputs": ["coverage/**"]
      },
      "test:watch": {
        "cache": false,
        "persistent": true
      },
      "clean": {
        "cache": false
      }
    }
  }