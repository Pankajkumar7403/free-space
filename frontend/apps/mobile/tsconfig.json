{
    "extends": "@qommunity/config/tsconfig/react-native",
    "compilerOptions": {
      "baseUrl": ".",
      "paths": {
        "@/*":                   ["./src/*"],
        "@qommunity/types":      ["../../packages/types/src/index.ts"],
        "@qommunity/api-client": ["../../packages/api-client/src/index.ts"],
        "@qommunity/validators": ["../../packages/validators/src/index.ts"],
        "@qommunity/ui-kit":     ["../../packages/ui-kit/src/index.ts"]
      }
    },
    "include": [
      "app/**/*.ts",
      "app/**/*.tsx",
      "src/**/*.ts",
      "src/**/*.tsx",
      "*.ts",
      "*.tsx"
    ],
    "exclude": ["node_modules"]
  }