{
    "name": "mobile",
    "version": "0.0.1",
    "private": true,
    "main": "expo-router/entry",
    "scripts": {
      "dev":           "expo start",
      "dev:ios":       "expo start --ios",
      "dev:android":   "expo start --android",
      "build:preview": "eas build --profile preview --platform all",
      "build:prod":    "eas build --profile production --platform all",
      "submit:ios":    "eas submit --platform ios",
      "submit:android":"eas submit --platform android",
      "lint":          "eslint . --ext .ts,.tsx",
      "type-check":    "tsc --noEmit",
      "test":          "jest --passWithNoTests",
      "test:watch":    "jest --watch",
      "clean":         "rm -rf .expo dist coverage"
    },
    "dependencies": {
      "expo":                          "~51.0.0",
      "expo-router":                   "~3.5.0",
      "expo-status-bar":               "~1.12.1",
      "expo-font":                     "~12.0.10",
      "expo-splash-screen":            "~0.27.5",
      "expo-secure-store":             "~13.0.2",
      "expo-image":                    "~1.12.15",
      "expo-image-picker":             "~15.0.7",
      "expo-notifications":            "~0.28.18",
      "expo-linking":                  "~6.3.1",
      "expo-constants":                "~16.0.2",
      "expo-av":                       "~14.0.7",
      "expo-blur":                     "~13.0.2",
      "expo-haptics":                  "~13.0.1",
      "@expo-google-fonts/sora":       "^0.2.3",
      "@expo-google-fonts/dm-sans":    "^0.2.3",
      "lucide-react-native":           "^0.400.0",
      "react":                         "18.2.0",
      "react-native":                  "0.74.3",
      "react-native-reanimated":       "~3.10.1",
      "react-native-gesture-handler":  "~2.16.2",
      "react-native-safe-area-context":"4.10.5",
      "react-native-screens":          "3.31.1",
      "react-native-svg":              "15.2.0",
      "nativewind":                    "^4.0.1",
      "@tanstack/react-query":         "^5.50.0",
      "zustand":                       "^4.5.4",
      "react-hook-form":               "^7.52.0",
      "@hookform/resolvers":           "^3.9.0",
      "zod":                           "^3.23.0",
      "axios":                         "^1.7.2",
      "@qommunity/types":              "workspace:*",
      "@qommunity/api-client":         "workspace:*"
    },
    "devDependencies": {
      "@babel/core":                   "^7.24.0",
      "babel-preset-expo":             "~11.0.14",
      "typescript":                    "^5.4.0",
      "@types/react":                  "~18.2.0",
      "jest":                          "^29.7.0",
      "jest-expo":                     "~51.0.3",
      "@testing-library/react-native": "^12.5.1",
      "@qommunity/config":             "workspace:*"
    }
  }